# Copy to .env (or export in your shell). Only the provider you choose needs a key.

# Choose the provider: anthropic | openai | glm  (overrides config.json)
SIDEQUEST_PROVIDER=glm

# --- GLM (Zhipu / z.ai, OpenAI-compatible; cheap/free = glm-4.5-flash) ---
GLM_API_KEY=
# Optional: override endpoint (default https://api.z.ai/api/paas/v4)
# GLM_BASE_URL=

# --- Anthropic (cheap = claude-haiku) ---
ANTHROPIC_API_KEY=

# --- OpenAI (cheap = gpt-4o-mini) ---
OPENAI_API_KEY=

# Optional: localhost port the TUI listens on for agent events (hooks must match). Default 4317.
SIDEQUEST_PORT=4317
